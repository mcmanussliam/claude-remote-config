{
  "name": "claude-remote-config",
  "version": "0.1.0",
  "description": "Claude Code plugin for maintaining shared versioned Claude configurations.",
  "type": "module",
  "bin": {
    "claude-remote-config": "./bin/claude-remote-config"
  },
  "files": [
    "bin/",
    "dist/",
    ".claude-plugin/",
    "hooks/",
    "README.md"
  ],
  "scripts": {
    "start": "tsx src/cli.ts",
    "build": "tsc -p tsconfig.build.json",
    "build:clean": "rm -rf dist && tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "commander": "12.1.0",
    "execa": "9.6.0",
    "fast-glob": "3.3.3",
    "gray-matter": "4.0.3",
    "yaml": "2.8.1",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/node": "20.19.25",
    "tsx": "4.20.6",
    "typescript": "5.9.3",
    "vitest": "2.1.9"
  },
  "engines": {
    "node": ">=18"
  }
}
